#!/usr/bin/env ruby
# frozen_string_literal: true

# usage: exifsearch <pattern> [dir]
# Batches multiple files per exiftool invocation to eliminate per-file
# startup overhead.

require 'json'
require 'open3'

EXTS = %w[jpg jpeg png heic heif tif tiff webp arw cr2 cr3 nef dng raf orf rw2].freeze

pattern_str = ARGV[0] or abort "usage: #{File.basename($PROGRAM_NAME)} <pattern> [dir]"
root        = File.expand_path(ARGV[1] || '.')
jobs        = (ENV['EXIFSEARCH_JOBS'] || '8').to_i

begin
  regex = Regexp.new(pattern_str, Regexp::IGNORECASE)
rescue RegexpError => e
  abort "Invalid regex: #{e.message}"
end

ext_flags = EXTS.flat_map { |e| ['-e', e] }
files = IO.popen(['fd', '--type', 'f', *ext_flags, '.', root], err: '/dev/null').read.split("\n")
exit 0 if files.empty?

# Divide files into exactly `jobs` batches so every thread does one call
batch_size = [(files.size.to_f / jobs).ceil, 1].max
batches    = files.each_slice(batch_size).to_a

found = []
mutex = Mutex.new

threads = batches.map do |batch|
  Thread.new(batch) do |b|
    out, = Open3.capture3(
      'exiftool', '-json', '-G1', '-all:all', '-charset', 'filename=utf8', '--', *b
    )
    records = begin; JSON.parse(out); rescue JSON::ParserError; []; end
    records.each do |data|
      file = data['SourceFile']
      next unless file
      match = data.any? do |k, v|
        k != 'SourceFile' && v.is_a?(String) && v.match?(regex)
      end
      mutex.synchronize { found << file } if match
    end
  end
end

threads.each(&:join)
found.sort.each { |f| puts f }

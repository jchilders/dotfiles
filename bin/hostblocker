#!/usr/bin/env ruby
# frozen_string_literal: true

require 'fileutils'
require 'open3'
require 'shellwords'
require 'set'

class CommandError < StandardError; end

class DnsCache
  TABLE_NAME = 'dns_cache'

  def initialize(path:, ttl_seconds:)
    @path = path
    @ttl_seconds = ttl_seconds
  end

  def init!
    FileUtils.mkdir_p(File.dirname(@path))
    sqlite(<<~SQL)
      CREATE TABLE IF NOT EXISTS #{TABLE_NAME} (
        domain TEXT PRIMARY KEY,
        ips TEXT,
        timestamp INTEGER
      );
    SQL
  end

  def fetch(domain)
    cutoff = Time.now.to_i - @ttl_seconds
    output, = sqlite(<<~SQL, allow_failure: true)
      SELECT ips
      FROM #{TABLE_NAME}
      WHERE domain = #{sql_quote(domain)}
        AND timestamp > #{cutoff};
    SQL

    parse_ips(output.lines.first)
  end

  def write(domain, ips)
    sqlite(<<~SQL)
      INSERT OR REPLACE INTO #{TABLE_NAME} (domain, ips, timestamp)
      VALUES (
        #{sql_quote(domain)},
        #{sql_quote(ips.join(','))},
        #{Time.now.to_i}
      );
    SQL
  end

  def clear!
    return unless File.exist?(@path)

    sqlite("DELETE FROM #{TABLE_NAME};", allow_failure: true)
  end

  private

  def parse_ips(value)
    value.to_s.strip.split(',').reject(&:empty?)
  end

  def sql_quote(value)
    "'#{value.to_s.gsub("'", "''")}'"
  end

  def sqlite(sql, allow_failure: false)
    stdout, stderr, status = Open3.capture3('sqlite3', @path, sql)
    return [stdout, stderr] if status.success? || allow_failure

    raise CommandError, stderr.empty? ? 'sqlite3 command failed' : stderr.strip
  end
end

class Hostblocker
  CONFIG_DIR = File.join(ENV.fetch('XDG_CONFIG_HOME', File.join(Dir.home, '.config')), 'hostblocker')
  DATA_DIR = File.join(ENV.fetch('XDG_DATA_HOME', File.join(Dir.home, '.local', 'share')), 'hostblocker')
  BLOCKLIST_FILE = File.join(CONFIG_DIR, 'blocked-domains')
  CACHE_DB = File.join(DATA_DIR, 'dns_cache.db')
  PF_TABLE = 'blocked'
  TTL_SECONDS = 86_400
  IPV4_PATTERN = /\A\d{1,3}(?:\.\d{1,3}){3}\z/
  ANSI_STYLES = {
    reset: "\e[0m",
    bold: "\e[1m",
    dim: "\e[2m",
    red: "\e[31m",
    green: "\e[32m",
    yellow: "\e[33m",
    blue: "\e[34m",
    magenta: "\e[35m",
    cyan: "\e[36m"
  }.freeze

  def initialize(command, editor: ENV.fetch('EDITOR', 'vi'))
    @command = command
    @editor = editor
    @cache = DnsCache.new(path: CACHE_DB, ttl_seconds: TTL_SECONDS)
  end

  def run
    case @command
    when 'enable'
      enable
    when 'reload'
      enable(force_reload: true)
    when 'disable'
      disable
    when 'status'
      status
    when 'edit-config'
      edit_config
    else
      usage!
    end
  end

  private

  def enable(force_reload: false)
    ensure_blocklist!
    domains = blocked_domains

    @cache.init!
    puts title_line(force_reload ? 'Reloading blocklist' : 'Updating blocklist', tone: force_reload ? :yellow : :cyan)

    if force_reload
      flush_pf_table
      @cache.clear!
    end

    current_ips = pf_table_ips.to_set
    desired_ips = []
    resolved_domain_count = 0

    domains.each do |domain|
      ips = resolved_ips_for(domain, refresh: force_reload)
      next if ips.empty?

      desired_ips.concat(ips)
      resolved_domain_count += 1
    end

    desired_ips = desired_ips.uniq

    if !force_reload && blocking_enabled?(current_ips) && desired_ips.to_set == current_ips
      puts status_line('Already enabled', tone: :green)
      return
    end

    if desired_ips.empty?
      puts status_line('No IPs resolved; nothing to update', tone: :yellow)
      return
    end

    load_pf_rules
    replace_pf_table(desired_ips)

    puts status_line('Blocking active', tone: :green)
    puts "  #{blocking_message(desired_ips.size, resolved_domain_count)}"
  end

  def disable
    puts title_line('Disabling blocklist', tone: :yellow)
    flush_pf_table
    run_command('sudo', 'pfctl', '-f', '-', stdin_data: "# blocklist disabled\n", allow_failure: true)
    puts status_line('Blocking disabled', tone: :yellow)
  end

  def status
    ensure_blocklist!

    current_ips = pf_table_ips
    if current_ips.empty?
      puts title_line('Hostblocker status', tone: :blue)
      puts status_line('DISABLED', tone: :yellow)
      return
    end

    puts title_line('Hostblocker status', tone: :blue)
    puts status_line('ENABLED', tone: :green)
    puts "  #{blocking_summary(current_ips.size, blocked_domains.size)}"
    puts "  #{paint(BLOCKLIST_FILE, :dim)}"
    puts
    puts table_row('DOMAIN', 'IPS', left_styles: %i[bold cyan], right_styles: %i[bold cyan])
    puts table_row('------', '---', left_styles: [:dim], right_styles: [:dim])

    blocked_domains.each do |domain|
      ips = resolve_domain(domain)
      row = if ips.empty?
        paint('(no A records)', :dim, :yellow)
      else
        ips.join(paint(' • ', :dim))
      end

      puts table_row(domain, row, left_styles: [:bold])
    end
  end

  def edit_config
    FileUtils.mkdir_p(CONFIG_DIR)
    editor_command = Shellwords.split(@editor)
    editor_command = ['vi'] if editor_command.empty?
    exec(*editor_command, BLOCKLIST_FILE)
  end

  def ensure_blocklist!
    return if File.exist?(BLOCKLIST_FILE)

    raise CommandError, "Error: #{BLOCKLIST_FILE} not found."
  end

  def blocked_domains
    @blocked_domains ||= File.readlines(BLOCKLIST_FILE, chomp: true).filter_map do |line|
      domain = line.strip
      next if domain.empty? || domain.start_with?('#')

      domain
    end
  end

  def resolved_ips_for(domain, refresh:)
    cached_ips = refresh ? [] : @cache.fetch(domain)
    if cached_ips.any?
      puts step_line('cached', domain, tone: :blue)
      return cached_ips
    end

    puts step_line('resolve', domain, tone: :magenta)
    resolved_ips = resolve_domain(domain)

    if resolved_ips.empty?
      puts "  #{paint('no A records found', :dim, :yellow)}"
    else
      @cache.write(domain, resolved_ips)
      puts "  #{paint(resolved_ips.join(' '), :dim)}"
    end

    resolved_ips
  end

  def resolve_domain(domain)
    stdout, = run_command('dig', '+short', domain, allow_failure: true)
    stdout.lines.map(&:strip).grep(IPV4_PATTERN)
  end

  def pf_table_ips
    stdout, = run_command('sudo', 'pfctl', '-t', PF_TABLE, '-T', 'show', allow_failure: true)
    stdout.lines.map(&:strip).reject(&:empty?)
  end

  def blocking_enabled?(current_ips)
    !current_ips.empty?
  end

  def flush_pf_table
    run_command('sudo', 'pfctl', '-t', PF_TABLE, '-T', 'flush', allow_failure: true)
  end

  def load_pf_rules
    pf_rules = <<~RULES
      table <#{PF_TABLE}> persist
      block drop out quick to <#{PF_TABLE}>
    RULES

    run_command('sudo', 'pfctl', '-f', '-', stdin_data: pf_rules, failure_message: 'Error loading pf rules')
  end

  def replace_pf_table(ips)
    run_command(
      'sudo',
      'pfctl',
      '-t',
      PF_TABLE,
      '-T',
      'replace',
      *ips,
      failure_message: 'Error updating pf table'
    )
  end

  def run_command(*command, stdin_data: nil, allow_failure: false, failure_message: nil)
    stdout, stderr, status = Open3.capture3(*command, stdin_data: stdin_data)
    return [stdout, stderr] if status.success? || allow_failure

    message = failure_message || stderr.strip
    message = "Command failed: #{command.join(' ')}" if message.nil? || message.empty?

    raise CommandError, message
  end

  def blocking_message(ip_count, domain_count)
    "Blocking #{ip_count} #{pluralize(ip_count, 'IP', 'IPs')} " \
      "for #{domain_count} #{pluralize(domain_count, 'domain', 'domains')} " \
      "from #{BLOCKLIST_FILE}"
  end

  def blocking_summary(ip_count, domain_count)
    "Blocking #{ip_count} #{pluralize(ip_count, 'IP', 'IPs')} " \
      "for #{domain_count} #{pluralize(domain_count, 'domain', 'domains')}"
  end

  def pluralize(count, singular, plural)
    count == 1 ? singular : plural
  end

  def usage!
    raise CommandError, <<~USAGE
      #{title_line('Hostblocker', tone: :cyan)}

      #{paint('Usage:', :bold)} hostblocker <command>

      Commands:
        #{paint('enable', :green)}       Enable / update blocklist
        #{paint('disable', :yellow)}      Disable blocklist
        #{paint('reload', :magenta)}       Re-resolve all domains and re-apply blocklist
        #{paint('status', :blue)}       Show blocked domains and their IPs
        #{paint('edit-config', :cyan)}  Open blocked-domains in $EDITOR
    USAGE
  end

  def title_line(text, tone:)
    "#{paint('==>', :bold, tone)} #{paint(text, :bold)}"
  end

  def status_line(text, tone:)
    "#{paint('[hostblocker]', :bold, tone)} #{paint(text, :bold)}"
  end

  def step_line(action, domain, tone:)
    "#{paint(action.upcase.ljust(7), :bold, tone)} #{paint(domain, :bold)}"
  end

  def table_row(left, right, width: 22, left_styles: [], right_styles: [])
    formatted_left = paint(left.ljust(width), *left_styles)
    formatted_right = paint(right, *right_styles)
    "#{formatted_left} #{formatted_right}"
  end

  def paint(text, *styles)
    return text unless color?

    codes = styles.filter_map { |style| ANSI_STYLES[style] }.join
    return text if codes.empty?

    "#{codes}#{text}#{ANSI_STYLES[:reset]}"
  end

  def color?
    return false if ENV.key?('NO_COLOR')
    return true if ENV['CLICOLOR_FORCE'] == '1' || ENV['FORCE_COLOR'] == '1'

    $stdout.tty?
  end
end

begin
  Hostblocker.new(ARGV.first).run
rescue CommandError => e
  abort e.message
end

#!/usr/bin/env ruby

require 'open3'
require 'json'
require 'optparse'
require 'tmpdir'

LAST_IMG_FILE = File.join(Dir.tmpdir, 'rimg_last')

show_models = false
show_prompts = false
force_random = false
OptionParser.new do |opts|
  opts.on('-m', '--models', 'Print model table from Generation data EXIF field') { show_models = true }
  opts.on('-M', '--random', 'Show a random image with model table, ignoring the last-viewed cache') { force_random = true; show_models = true }
  opts.on('-p', '--prompts', 'Print positive and negative prompts from Generation data EXIF field') { show_prompts = true }
end.parse!

img = ARGV.shift

if img && File.directory?(img)
  imgs = Dir.glob(File.join(img, '**/*.{gif,jpg,jpeg,png,webp,mp4,webm}')).select { |i| File.file?(i) }
  abort "No images found in: #{img}" if imgs.empty?
  img = imgs.sample
elsif img
  abort "File not found: #{img}" unless File.file?(img)
elsif !force_random && (show_models || show_prompts) && File.file?(LAST_IMG_FILE)
  img = File.read(LAST_IMG_FILE).strip
  abort "Last image not found: #{img}" unless File.file?(img)
else
  imgs = Dir.glob('**/*.{gif,jpg,jpeg,png,webp,mp4,webm}').select { |i| File.file?(i) }
  abort 'No images found.' if imgs.empty?
  img = imgs.sample
end

File.write(LAST_IMG_FILE, img)

system('timg', img)

exif_json, = Open3.capture2('exiftool', '-j', img)
exif = JSON.parse(exif_json).first rescue {}

gen_key = exif.keys.find { |k| k.match?(/generation.?data/i) }
has_gen_data = gen_key || exif.keys.any? { |k| k.match?(/prompt/i) }

puts has_gen_data ? "#{img} *" : img

if (show_models || show_prompts) && gen_key
  gen_data = JSON.parse(exif[gen_key]) rescue nil
  if gen_data
    if show_prompts
      puts
      puts "Prompt:   #{gen_data['prompt']}"
      puts "Negative: #{gen_data['negativePrompt']}"
    end

    if show_models
      models = [gen_data['baseModel']].compact + Array(gen_data['models'])

      col_widths = {
        type:  [models.map { |m| m['type'].to_s.length }.max, 4].max,
        label: [models.map { |m| m['label'].to_s.length }.max, 5].max,
        name:  [models.map { |m| m['modelFileName'].to_s.length }.max, 5].max,
      }

      header = "%-#{col_widths[:type]}s  %-#{col_widths[:label]}s  %-#{col_widths[:name]}s  %s" %
               %w[Type Label Model Hash]
      puts
      puts header
      puts '-' * header.length
      models.each do |m|
        puts "%-#{col_widths[:type]}s  %-#{col_widths[:label]}s  %-#{col_widths[:name]}s  %s" %
             [m['type'], m['label'], m['modelFileName'], m['hash']]
      end
    end
  else
    puts '(Generation data found but could not parse as JSON)'
  end
end

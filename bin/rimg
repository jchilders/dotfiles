#!/usr/bin/env ruby

require 'open3'
require 'json'
require 'optparse'
require 'tmpdir'
require 'io/console'
require 'net/http'

LAST_IMG_FILE = File.join(Dir.tmpdir, 'rimg_last')
DT_PORT = ENV.fetch('DT_PORT', '7860')
IMG_GLOB = '**/*.{gif,jpg,jpeg,png,webp,mp4,webm}'

BOLD  = "\e[1m"
ULINE = "\e[4m"
RESET = "\e[0m"

# Render a word with its first letter bold + underlined to mark its hotkey.
def cmd(word)
  "#{BOLD}#{ULINE}#{word[0]}#{RESET}#{word[1..]}"
end

# Render a whole word bold + underlined (for multi-char keys like space/esc).
def key(word)
  "#{BOLD}#{ULINE}#{word}#{RESET}"
end

# Draw Things stores LoRAs under "v2.loras" (each with a "file" key); older/other
# variants used a top-level "lora" list (each with a "model" key). Normalize both
# to a list of {file, weight}.
def dt_loras(dt)
  raw = dt.dig('v2', 'loras')
  raw = dt['lora'] if raw.nil? || raw.empty?
  Array(raw)
    .map { |l| { 'file' => l['file'] || l['model'], 'weight' => l['weight'] } }
    .reject { |l| l['file'].to_s.empty? }
end

def read_metadata(img)
  exif_json, = Open3.capture2('exiftool', '-j', img)
  exif = JSON.parse(exif_json).first rescue {}

  # Draw Things stores its generation data as JSON in the "User Comment" field,
  # flagged by a "Creator Tool" of "Draw Things". Normalize it into the same
  # shape used for the "Generation data" field so the rest of the script is shared.
  draw_things = exif['CreatorTool'].to_s.strip == 'Draw Things'
  dt_data = (JSON.parse(exif['UserComment']) rescue nil) if draw_things
  gen_key = exif.keys.find { |k| k.match?(/generation.?data/i) }

  gen_data =
    if dt_data
      {
        'prompt'         => dt_data['c'],
        'negativePrompt' => dt_data['uc'],
        'baseModel'      => { 'type' => 'base', 'modelFileName' => dt_data['model'] },
        'models'         => dt_loras(dt_data).map do |l|
          { 'type' => 'lora', 'modelFileName' => l['file'], 'weight' => l['weight'] }
        end,
      }
    elsif gen_key
      JSON.parse(exif[gen_key]) rescue nil
    end

  { exif: exif, gen_data: gen_data, gen_key: gen_key, draw_things: draw_things, dt_data: dt_data }
end

def display(img)
  File.write(LAST_IMG_FILE, img)
  system('timg', img)
  meta = read_metadata(img)
  has_gen_data = meta[:gen_data] || meta[:gen_key] || meta[:draw_things] ||
                 meta[:exif].keys.any? { |k| k.match?(/prompt/i) }
  puts has_gen_data ? "#{img} *" : img
  meta
end

def print_prompts(gen_data)
  puts
  puts "Prompt:   #{gen_data['prompt']}"
  puts "Negative: #{gen_data['negativePrompt']}"
end

def print_models(gen_data)
  models = [gen_data['baseModel']].compact + Array(gen_data['models'])

  col_widths = {
    type:   [models.map { |m| m['type'].to_s.length }.max, 4].max,
    label:  [models.map { |m| m['label'].to_s.length }.max, 5].max,
    name:   [models.map { |m| m['modelFileName'].to_s.length }.max, 5].max,
    weight: [models.map { |m| m['weight'].to_s.length }.max, 6].max,
  }

  header = "%-#{col_widths[:type]}s  %-#{col_widths[:label]}s  %-#{col_widths[:name]}s  %-#{col_widths[:weight]}s  %s" %
           %w[Type Label Model Weight Hash]
  puts
  puts header
  puts '-' * header.length
  models.each do |m|
    puts "%-#{col_widths[:type]}s  %-#{col_widths[:label]}s  %-#{col_widths[:name]}s  %-#{col_widths[:weight]}s  %s" %
         [m['type'], m['label'], m['modelFileName'], m['weight'], m['hash']]
  end
end

def print_exif(meta)
  exif = meta[:exif]
  if exif.nil? || exif.empty?
    puts '(No EXIF data)'
    return
  end
  width = exif.keys.map(&:length).max
  puts
  exif.each do |k, v|
    puts "%-#{width}s  %s" % [k, v]
  end
end

# Build a Draw Things txt2img request body from an image's generation metadata.
# Handles both Draw Things' own "User Comment" JSON (dt_data) and the generic
# "Generation data" field shape. Returns nil if there's nothing to send.
def dt_body(meta)
  if (dt = meta[:dt_data])
    v2 = dt['v2'] || {}
    body = { 'prompt' => dt['c'].to_s, 'batch_count' => 1 }
    body['negative_prompt'] = dt['uc']          unless dt['uc'].to_s.empty?
    body['model']           = dt['model']       if dt['model']
    body['sampler_name']    = dt['sampler']     if dt['sampler']
    body['seed']            = dt['seed']        if dt['seed']
    body['steps']           = dt['steps']       if dt['steps']
    body['guidance_scale']  = v2['guidanceScale'] if v2['guidanceScale']
    if dt['size'].to_s =~ /(\d+)\s*x\s*(\d+)/
      body['width'], body['height'] = $1.to_i, $2.to_i
    elsif v2['width'] && v2['height']
      body['width'], body['height'] = v2['width'], v2['height']
    end
    loras = dt_loras(dt)
    body['loras'] = loras unless loras.empty?
    body
  elsif (g = meta[:gen_data]) && !g['prompt'].to_s.empty?
    body = { 'prompt' => g['prompt'].to_s, 'batch_count' => 1 }
    body['negative_prompt'] = g['negativePrompt'] unless g['negativePrompt'].to_s.empty?
    body['seed']           = g['seed'].to_i  if g['seed']
    body['steps']          = g['steps'].to_i if g['steps']
    body['guidance_scale'] = g['cfgScale'].to_f if g['cfgScale']
    body['sampler_name']   = g['samplerName'] if g['samplerName']
    body['width']          = g['width'].to_i  if g['width']
    body['height']         = g['height'].to_i if g['height']
    base = g['baseModel'] && g['baseModel']['modelFileName']
    body['model'] = base if base
    loras = Array(g['models'])
            .select { |m| m['type'] == 'lora' }
            .map { |m| { 'file' => m['modelFileName'], 'weight' => m['weight'] } }
            .reject { |l| l['file'].to_s.empty? }
    body['loras'] = loras unless loras.empty?
    body
  end
end

def send_to_dt(meta)
  body = dt_body(meta)
  if body.nil? || body['prompt'].to_s.empty?
    puts '(No generation data to send)'
    return
  end

  uri = URI("http://localhost:#{DT_PORT}/sdapi/v1/txt2img")
  req = Net::HTTP::Post.new(uri, 'Content-Type' => 'application/json')
  req.body = JSON.generate(body)

  done = false
  spinner = Thread.new do
    frames = '⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'.chars
    i = 0
    until done
      print "\r#{frames[i % frames.length]} Sending to Draw Things…"
      i += 1
      sleep 0.1
    end
  end

  begin
    res = Net::HTTP.start(uri.host, uri.port, read_timeout: 600) { |http| http.request(req) }
  rescue StandardError => e
    done = true; spinner.join; print "\r\e[K"
    puts "Could not reach Draw Things on port #{DT_PORT}: #{e.message}"
    puts 'Enable it in Draw Things → Settings → API Server.'
    return
  end
  done = true; spinner.join; print "\r\e[K"

  if res.is_a?(Net::HTTPSuccess)
    puts "Sent to Draw Things (seed #{body['seed'] || 'random'})."
  else
    puts "Draw Things returned HTTP #{res.code}: #{res.body.to_s[0, 300]}"
  end
end

def print_metadata(meta, models:, prompts:)
  if meta[:gen_data]
    print_prompts(meta[:gen_data]) if prompts
    print_models(meta[:gen_data]) if models
  elsif meta[:gen_key] || meta[:draw_things]
    puts '(Generation data found but could not parse as JSON)'
  else
    puts '(No generation data)'
  end
end

show_models = false
show_prompts = false
show_json = false
force_random = false
OptionParser.new do |opts|
  opts.on('-m', '--models', 'Print model table from Generation data EXIF field') { show_models = true }
  opts.on('-M', '--random', 'Show a random image with model table, ignoring the last-viewed cache') { force_random = true; show_models = true }
  opts.on('-p', '--prompts', 'Print positive and negative prompts from Generation data EXIF field') { show_prompts = true }
  opts.on('-j', '--json', 'Output Prompt and Generation data EXIF fields as JSON') { show_json = true }
end.parse!

img = ARGV.shift
imgs = nil

if img && File.directory?(img)
  imgs = Dir.glob(File.join(img, IMG_GLOB)).select { |i| File.file?(i) }
  abort "No images found in: #{img}" if imgs.empty?
  img = imgs.sample
elsif img
  abort "File not found: #{img}" unless File.file?(img)
elsif !force_random && (show_models || show_prompts || show_json) && File.file?(LAST_IMG_FILE)
  img = File.read(LAST_IMG_FILE).strip
  abort "Last image not found: #{img}" unless File.file?(img)
else
  imgs = Dir.glob(IMG_GLOB).select { |i| File.file?(i) }
  abort 'No images found.' if imgs.empty?
  img = imgs.sample
end

if show_json
  File.write(LAST_IMG_FILE, img)
  meta = read_metadata(img)
  exif = meta[:exif]
  output = { file: img }
  if meta[:dt_data]
    output[:prompt] = meta[:dt_data]['c']
    output[:generation_data] = meta[:dt_data]
  else
    prompt_key = exif.keys.find { |k| k.match?(/\Aprompt\z/i) }
    output[:prompt] = exif[prompt_key] if prompt_key
    output[:generation_data] = (JSON.parse(exif[meta[:gen_key]]) rescue exif[meta[:gen_key]]) if meta[:gen_key]
  end
  puts JSON.generate(output)
  exit
end

meta = display(img)

if show_models || show_prompts
  print_metadata(meta, models: show_models, prompts: show_prompts)
  exit
end

exit unless $stdin.tty?

loop do
  exif_cmd = "e#{BOLD}#{ULINE}x#{RESET}if"
  print "\n#{key('space')} next | #{cmd('models')} | #{cmd('prompts')} | #{cmd('all')} | #{exif_cmd} | #{cmd('send')} to DT | #{cmd('review')} | #{cmd('quit')} "
  ch = begin
    $stdin.getch
  rescue Interrupt
    "\e"
  end
  print "\r\e[K"

  case ch
  when ' ', "\x7f", "\b"
    imgs ||= Dir.glob(IMG_GLOB).select { |i| File.file?(i) }
    imgs.empty? ? puts('No images found.') : meta = display(img = imgs.sample)
  when 'r'
    meta = display(img)
  when 'm'
    print_metadata(meta, models: true, prompts: false)
  when 'p'
    print_metadata(meta, models: false, prompts: true)
  when 'a'
    print_metadata(meta, models: true, prompts: true)
  when 'x'
    print_exif(meta)
  when 's'
    send_to_dt(meta)
  when "q", "\u0003" # ctrl+c (raw mode delivers it as a byte)
    # Drain any escape-sequence tail (e.g. arrow keys) so it doesn't leak into the shell
    ($stdin.raw { $stdin.read_nonblock(16) } rescue nil) if ch == "\e"
    break
  end
end
